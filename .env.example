# Asaas API Configuration
# Get your API key from Asaas Sandbox (https://sandbox.asaas.com/) ou Produção (https://asaas.com/)
ASAAS_API_KEY=your_asaas_api_key_here
# Sandbox (padrão). Para produção use: https://api.asaas.com/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
# Optional: customer ID used when creating payments if no customer is created (sandbox example)
# ASAAS_DEFAULT_CUSTOMER_ID=cus_000005041334
# Wallet da conta da plataforma: usado no split quando a loja não tem asaas_wallet_id (create-payment).
# Não commitar o valor real; configurar em Supabase Dashboard → Settings → Edge Functions → Secrets.
# ASAAS_WALLET_ID=c1c11850-aced-4867-9401-6f25a4cbc2f2
# Token do webhook Asaas (obrigatório para asaas-webhook em modo seguro/fail-closed)
# ASAAS_WEBHOOK_TOKEN=seu_token_de_webhook_asaas
#
# Provisionador externo de subcontas (profissionais)
# Endpoint da função create-subaccount do projeto "plataforma-subcontas"
# ASAAS_PROVISIONER_URL=https://SEU-PROJETO.supabase.co/functions/v1/create-subaccount
# ASAAS_PROVISIONER_APP_ID=UUID_DO_APP_BARBEARIA_NO_PROVISIONADOR
# ASAAS_PROVISIONER_TOKEN=token_opcional_se_houver_gateway
# ASAAS_PROVISIONER_ENV=sandbox
#
# Provisionamento assíncrono da LOJA (Edge process-shop-finance + webhook)
# Segredo para o provisionador externo chamar shop-finance-webhook (Bearer).
# SHOP_FINANCE_WEBHOOK_SECRET=defina_um_segredo_longo_aleatorio
# Opcional: delegar criação de subconta da loja a outro sistema (então status = awaiting_callback até o webhook).
# ASAAS_SHOP_PROVISIONER_URL=https://SEU-PROJETO.supabase.co/functions/v1/create-shop-subaccount
# ASAAS_SHOP_PROVISIONER_APP_ID=UUID_DO_APP
# ASAAS_SHOP_PROVISIONER_TOKEN=token_opcional

# Supabase Configuration
# Project ID: wevcqosziiwfbxbmjqln
VITE_SUPABASE_URL=https://wevcqosziiwfbxbmjqln.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Para rotas de API no Vercel (api/admin/shops): use SUPABASE_URL ou deixe em branco para usar VITE_SUPABASE_URL
# SUPABASE_URL=https://wevcqosziiwfbxbmjqln.supabase.co
# Senha do banco (Dashboard → Settings → Database). O `npm run db:push` lê isto quando o CLI dá 403 no "login role".
# SUPABASE_DB_PASSWORD=

# Connection string alternativa para `npm run db:push:url` (Session pooler, porta 6543)
# SUPABASE_DB_URL=postgresql://postgres.wevcqosziiwfbxbmjqln:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
