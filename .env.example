# Asaas API Configuration
# Get your API key from Asaas Sandbox (https://sandbox.asaas.com/)
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
# Optional: customer ID used when creating payments if no customer is created (sandbox example)
# ASAAS_DEFAULT_CUSTOMER_ID=cus_000005041334
# Wallet da conta principal: usado no split quando a loja não tem asaas_wallet_id (create-payment)
# ASAAS_WALLET_ID=wal_xxxx

# Supabase Configuration
# Project ID: wevcqosziiwfbxbmjqln
VITE_SUPABASE_URL=https://wevcqosziiwfbxbmjqln.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Para rotas de API no Vercel (api/admin/shops): use SUPABASE_URL ou deixe em branco para usar VITE_SUPABASE_URL
# SUPABASE_URL=https://wevcqosziiwfbxbmjqln.supabase.co
# Connection string para aplicar migrations via CLI (Dashboard → Settings → Database → URI)
# SUPABASE_DB_URL=postgresql://postgres.wevcqosziiwfbxbmjqln:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
